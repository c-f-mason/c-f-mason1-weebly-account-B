library(rvest,stringr)
pacman::p_load(pacman, tidyverse, tidyr, readxl, lubridate, haven, foreign, readr, rio, sjlabelled, rvest, stringr)
# read html of website
urlG = "https://www.eia.gov/petroleum/gasdiesel/gaspump_hist.php"
urlD = "https://www.eia.gov/petroleum/gasdiesel/dieselpump_hist.php"
pageG <- read_html(urlG)
pageD <- read_html(urlD)
#
# locate an element via xpath in the website
#
#  eia_tableG <- html_nodes(pageG, xpath = '/html/body/div[1]/div[2]/div/div[5]/div/div[1]/div/table')
eia_tableG <- html_nodes(pageG, xpath = '/html/body/div[1]/div[2]/div/div[4]/div/div[1]/div/table') %>%
html_table()
#
# eia_tableD <- html_nodes(pageD, xpath = '/html/body/div[1]/div[2]/div/div[5]/div/div[1]/div/table')
eia_tableD <- html_nodes(pageD, xpath = '/html/body/div[1]/div[2]/div/div[4]/div/div[1]/div/table') %>%
html_table()
#
#html_table()  # make the element the table
# convert the table to dataframe#
#
dfG <- do.call(rbind.data.frame, eia_tableG)
dfD <- do.call(rbind.data.frame, eia_tableD)
# rename 'Month-year' to 'mmmyy'
names(dfG)[1] <- "mmmyy"
names(dfD)[1] <- "mmmyy"
# new columns that split the column, `mmmyy` into month and year
mmmyyG <- str_split_fixed(dfG$mmmyy, "-", 2)
mmmyyD <- str_split_fixed(dfD$mmmyy, "-", 2)
# merging two dataframe
dfG <- data.frame(mmmyyG, dfG)
dfD <- data.frame(mmmyyD, dfD)
# renaming
nm1 <- c("month","year")
names(dfG)[1:2] <- nm1
names(dfD)[1:2] <- nm1
# drop the column of `mmmyy`
dfG <- subset(dfG, select = -c(mmmyy))
dfG$year<- as.numeric(dfG$year)
dfG$year<- dfG$year + 2000
#
dfD <- subset(dfD, select = -c(mmmyy))
dfD$year<- as.numeric(dfD$year)
dfD$year<- dfD$year + 2000
# add 2000 to year column
#df$year<-sub("^", "20", df$year)
# keep the first 3 characters in month column
dfG$month <- substr(dfG$month, 1, 3)
#
# convert abb. month to number
dfG$month <- match(dfG$month, month.abb)
dfD$month <- match(dfD$month, month.abb)
#
# change an order of columns
dfG <- dfG[,c(2,1,3,4,5,6,7)]
dfD <- dfD[,c(2,1,3,4,5,6,7)]
#summary(dfD)
names1 <- c("Refining", "Distribution_Marketing", "Taxes", "Crude_Oil_Price")
# renaming
names(dfG)[3] <- "Pgasoline"
names(dfG)[4:7] <- names1
names(dfD)[3] <- "Pdiesel"
names(dfD)[4:7] <- names1
label0 <- c(rep("", 2),"US Dollars / gallon",rep("percentage of price", 4))
set_label(dfG) <- label0
set_label(dfD) <- label0
# export dataframes to csv file
setwd("~/Dropbox/Energy Data/Excel")
#setwd("/Users/bambuzlr/Library/CloudStorage/Dropbox/Energy Data/Excel")
# setwd("/Users/chuckmason/Dropbox/Energy Data/Excel")
#
write.csv(dfG,"eia_gasoline_price_monthly.csv", row.names = FALSE)
write.csv(dfD,"eia_diesel_price_monthly.csv", row.names = FALSE)
#
# save as Stata files
#
write_stata(dfD,"eia_diesel_price_monthly.dta")
write_stata(dfG,"eia_gasoline_price_monthly.dta")
