#
# for: daily, weekly, monthly data
#
names.spot <- c("Date", "pHH")
names.fut <- c("Date", "NG_Fut1", "NG_Fut2", "NG_Fut3", "NG_Fut4")
# inlistSpot <- list("NG_PRI_FUT_S1_D.xls", "NG_PRI_FUT_S1_W.xls")
# inlistFut <- list("NG_PRI_FUT_S1_D.xls", "NG_PRI_FUT_S1_W.xls", "NG_PRI_FUT_S1_M.xls")
URLd <- "https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_D.xls"
URLw <- "https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_W.xls"
URLm <- "https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_M.xls"
inlistP <- c("https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_D.xls", "https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_W.xls", "https://www.eia.gov/dnav/ng/xls/NG_PRI_FUT_S1_M.xls")
TimeFrame <- c("D", "W", "M")
#
# spot price data
#
for (i in 1:3) {
pd <- TimeFrame[i]
fin <- inlistP[[i]]
fn <- import(fin, sheet = "Data 1",skip=3, col_names = FALSE)
fn <- fn[,1:2]
colnames(fn) <- names.spot
set_label(fn) <- c("date", "Henry Hub spot price, $/MMBtu")
fn$Date <- as.Date(fn$Date)
foutS <- paste0("NatGasSpotPriceEIA_", pd, ".dta")
write_dta(fn, foutS)
}
#
# foutR <- paste0("NatGasPrice_Spot_", pd, ".Rdata")
# save(fn, file = foutR)
#
# futures price data
#
for (i in 1:2) {
pd <- TimeFrame[i]
fin <- inlistP[[i]]
fn <- import(fin, sheet = "Data 2",skip=3, col_names = FALSE)
colnames(fn) <- names.fut
set_label(fn) <- c("date", "NYMEX futures price (contract 1), $/MMBtu", "NYMEX futures price (contract 2), $/MMBtu", "NYMEX futures price (contract 3), $/MMBtu", "NYMEX futures price (contract 4), $/MMBtu")
fn$Date <- as.Date(fn$Date)
foutS <- paste0("NatGasFuturesPriceEIA_", pd, ".dta")
write_dta(fn, foutS)
}
#
# foutR <- paste0("NatGasPrice_Futures_", pd, ".Rdata")
# save(fn, file = foutR)
#
# detailed description of consumption prices
#
web <- "https://www.eia.gov/dnav/ng/hist_xls/"
inlistPvar <- c("N3050US3m", "N3010US3m", "N3020US3m", "N3045US3m",  "N9102US3m", "N9103US3m")
inlist.name <- c("Citygate", "Residential", "Commercial", "Electric", "Pipeline_Imports", "LNG_Imports")
labels1 <- c("Citygate NG Price, $/Mcf" , "NG Price to Residential Consumers, $/Mcf" , "NG Price to Commercial Consumers, $/Mcf", "NG Price to Electiricity Producers, $/Mcf", "NG Pipeline Imports Price, $/Mcf", "Imported LNG Price, $/Mcf")
#labels2 <- c("Date", "NG Pipeline Imports Price, $/MCF", "Imported LNG Price, $/MCF")
#fnS <- import(finS, sheet = "Data 1", skip=3, col_names = FALSE)
#view(finS)
for (i in 1:6) {
fin <- inlistPvar[[i]]
finS <- paste0(web, fin, ".xls")
nameS <- inlist.name[[i]]
lbl <- labels1[[i]]
fnS <- import(finS, sheet = "Data 1", skip=3, col_names = FALSE)
view(fnS)
colnames(fnS) <- c("Date", nameS)
set_label(fnS) <- c("date", lbl)
fnS$Date <- as.Date(fnS$Date)
foutS <- paste0("NatGasPrice_", nameS, ".dta")
write_dta(fnS, foutS)
ifelse(i==1, foutSall <- fnS, ifelse(i < 4, foutSall <- cbind(foutSall,fnS), ifelse(i==5, foutSimp <- fnS, ifelse(i == 6, foutSimp <- cbind(foutSimp,fnS), foutSall))))
}
foutSall <- select(foutSall, -c(3,5))
colnames(foutSall) <- c("Date", "Citygate", "Residential", "Commercial")
foutSall <- filter(foutSall, !is.na(Residential))
write_dta(foutSall, "VariousNatGasPrices.dta")
foutSimp <- select(foutSimp, -3)
colnames(foutSimp) <- c("Date", "Pipeline_Imports", "LNG_Imports")
#names(foutSimp)[4] <-
foutSimp <- filter(foutSimp, !is.na(Pipeline_Imports))
write_dta(foutSimp, "NatGasImportPrices.dta")
#
# various NG prices
#
NGprices <- rio::import("https://www.eia.gov/dnav/ng/xls/NG_PRI_SUM_DCU_NUS_M.xls", sheet = "Data 1",skip=39, col_names = FALSE)
colnames(NGprices) <- c("Date", "pNGWellhead", "pNG_Imports", "pNG_ImportsPipeline", "pNG_ImportsLNG", "pNG_Exports", "pNG_ExportsPipeline", "pNG_ExportsLNG", "Citygate", "Residential","PctResidential", "Commercial","PctCommercial","Industrial","PctIndustrial","Electric")
pNGlbl <- import("https://www.eia.gov/dnav/ng/xls/NG_PRI_SUM_DCU_NUS_M.xls", sheet = "Data 1",skip=2, n_max = 1, col_names = FALSE)
#
pNGlabels <- pNGlbl[1,]
pNGlabels <- as.character(pNGlabels)
class(pNGlabels)
set_label(NGprices) <- pNGlabels
class(NGprices$Date)
NGprices$Date <- as.Date(NGprices$Date)
class(NGprices$Date)
#set_label(NGprices) <- pNGlabels[1,]
#labels(NGprices) <- pNGlabels
write_dta(NGprices, "NG_VariousHistoricalPrices.dta")
#
# LNG prices
#
pLNG <- import("https://www.eia.gov/dnav/ng/hist_xls/N9133US3m.xls", sheet = "Data 1",skip=2, col_names = TRUE)
pLNG$Date <- as.Date(pLNG$Date)
class(pLNG$Date)
pLNG[3] <- pLNG[2] * 1.037
pLNG$Year <- format(pLNG$Date, format="%Y")
pLNG <- filter(pLNG, pLNG$Year > 2000)
qLNG <- import("https://www.eia.gov/dnav/ng/hist_xls/N9133US2m.xls", sheet = "Data 1",skip=2, col_names = TRUE)
qLNG[2] <- qLNG[2]/1000
qLNG$Date <- as.Date(qLNG$Date)
class(qLNG$Date)
qLNG$Year <- format(qLNG$Date, format="%Y")
qLNG <- filter(qLNG, qLNG$Year > 2000)
qLNG <- merge(pLNG, qLNG, by = "Date")
qLNG <- qLNG[c(1,2,3,5)]
names(qLNG) <- c("Date", "pLNG", "pLNG1", "qLNG")
set_label(qLNG) <- c("date", "LNG price, $/Mcf", "LNG price, $/MMbtu", "Bcf")
qLNG$Date <- as.Date(qLNG$Date)
class(qLNG$Date)
write_dta(qLNG, "LNG_HistoricalData.dta")
library(rvest,stringr)
pacman::p_load(pacman, tidyverse, tidyr, readxl, lubridate, haven, foreign, readr, rio, sjlabelled, rvest, stringr)
# read html of website
urlG = "https://www.eia.gov/petroleum/gasdiesel/gaspump_hist.php"
urlD = "https://www.eia.gov/petroleum/gasdiesel/dieselpump_hist.php"
pageG <- read_html(urlG)
pageD <- read_html(urlD)
#
# locate an element via xpath in the website
#
#  eia_tableG <- html_nodes(pageG, xpath = '/html/body/div[1]/div[2]/div/div[5]/div/div[1]/div/table')
eia_tableG <- html_nodes(pageG, xpath = '/html/body/div[1]/div[2]/div/div[4]/div/div[1]/div/table') %>%
html_table()
#
# eia_tableD <- html_nodes(pageD, xpath = '/html/body/div[1]/div[2]/div/div[5]/div/div[1]/div/table')
eia_tableD <- html_nodes(pageD, xpath = '/html/body/div[1]/div[2]/div/div[4]/div/div[1]/div/table') %>%
html_table()
#
#html_table()  # make the element the table
# convert the table to dataframe#
#
dfG <- do.call(rbind.data.frame, eia_tableG)
dfD <- do.call(rbind.data.frame, eia_tableD)
# rename 'Month-year' to 'mmmyy'
names(dfG)[1] <- "mmmyy"
names(dfD)[1] <- "mmmyy"
# new columns that split the column, `mmmyy` into month and year
mmmyyG <- str_split_fixed(dfG$mmmyy, "-", 2)
mmmyyD <- str_split_fixed(dfD$mmmyy, "-", 2)
# merging two dataframe
dfG <- data.frame(mmmyyG, dfG)
dfD <- data.frame(mmmyyD, dfD)
# renaming
nm1 <- c("month","year")
names(dfG)[1:2] <- nm1
names(dfD)[1:2] <- nm1
# drop the column of `mmmyy`
dfG <- subset(dfG, select = -c(mmmyy))
dfG$year<- as.numeric(dfG$year)
dfG$year<- dfG$year + 2000
#
dfD <- subset(dfD, select = -c(mmmyy))
dfD$year<- as.numeric(dfD$year)
dfD$year<- dfD$year + 2000
# add 2000 to year column
#df$year<-sub("^", "20", df$year)
# keep the first 3 characters in month column
dfG$month <- substr(dfG$month, 1, 3)
#
# convert abb. month to number
dfG$month <- match(dfG$month, month.abb)
dfD$month <- match(dfD$month, month.abb)
#
# change an order of columns
dfG <- dfG[,c(2,1,3,4,5,6,7)]
dfD <- dfD[,c(2,1,3,4,5,6,7)]
#summary(dfD)
names1 <- c("Refining", "Distribution_Marketing", "Taxes", "Crude_Oil_Price")
# renaming
names(dfG)[3] <- "Pgasoline"
names(dfG)[4:7] <- names1
names(dfD)[3] <- "Pdiesel"
names(dfD)[4:7] <- names1
label0 <- c(rep("", 2),"US Dollars / gallon",rep("percentage of price", 4))
set_label(dfG) <- label0
set_label(dfD) <- label0
# export dataframes to csv file
setwd("~/Dropbox/Energy Data/Excel")
#setwd("/Users/bambuzlr/Library/CloudStorage/Dropbox/Energy Data/Excel")
# setwd("/Users/chuckmason/Dropbox/Energy Data/Excel")
#
write.csv(dfG,"eia_gasoline_price_monthly.csv", row.names = FALSE)
write.csv(dfD,"eia_diesel_price_monthly.csv", row.names = FALSE)
#
# save as Stata files
#
write_stata(dfD,"eia_diesel_price_monthly.dta")
write_stata(dfG,"eia_gasoline_price_monthly.dta")
